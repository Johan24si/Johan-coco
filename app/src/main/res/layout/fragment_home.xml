<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f172a">

    <!-- TOP BAR / TOOLBAR dengan overlay biru gelap transparan -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#CC0f172a"
        android:elevation="0dp"
        app:title="Home"
        app:titleTextColor="#f8fafc"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- GARIS PEMISAH TIPIS BAWAH TOOLBAR -->
    <View
        android:id="@+id/dividerToolbar"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#14FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/toolbar" />

    <!-- KONTEN UTAMA -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/bottomNavBarContainer"
        app:layout_constraintTop_toBottomOf="@id/dividerToolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ICON BRANDING -->
            <androidx.cardview.widget.CardView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="4dp"
                app:cardBackgroundColor="#26ff7a00"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_launcher_foreground"
                    app:tint="#ff7a00" />
            </androidx.cardview.widget.CardView>

            <!-- JUDUL WELCOME -->
            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="sans-serif-black"
                android:text="@string/welcome_text"
                android:textColor="#f8fafc"
                android:textSize="32sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02" />

            <!-- SUBTITLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="20dp"
                android:text="@string/silahkan_pilih"
                android:textColor="#94a3b8"
                android:textSize="14sp" />

            <!-- ROW 1: Pertemuan 2 dan 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- CARD PERTEMUAN 2 — Oranye -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/btnToSecond"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#ff7a00">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="14dp">

                        <View
                            android:layout_width="70dp"
                            android:layout_height="70dp"
                            android:background="@drawable/shape_circle_white"
                            android:alpha="0.15"
                            android:layout_alignParentTop="true"
                            android:layout_alignParentEnd="true"
                            android:layout_marginTop="-14dp"
                            android:layout_marginEnd="-14dp" />

                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:gravity="center"
                            android:text="P2"
                            android:textColor="#ffffff"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:background="@drawable/shape_badge_white"
                            android:layout_alignParentTop="true"
                            android:layout_alignParentStart="true" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_alignParentBottom="true"
                            android:layout_alignParentStart="true">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/pertemuan_2"
                                android:textColor="#ffffff"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Materi &amp; Tugas"
                                android:textColor="#CCFFFFFF"
                                android:textSize="11sp" />
                        </LinearLayout>

                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

                <!-- CARD PERTEMUAN 3 — Pink -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/btnToThird"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#f43f5e">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="14dp">

                        <View
                            android:layout_width="70dp"
                            android:layout_height="70dp"
                            android:background="@drawable/shape_circle_white"
                            android:alpha="0.15"
                            android:layout_alignParentTop="true"
                            android:layout_alignParentEnd="true"
                            android:layout_marginTop="-14dp"
                            android:layout_marginEnd="-14dp" />

                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:gravity="center"
                            android:text="P3"
                            android:textColor="#ffffff"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:background="@drawable/shape_badge_white"
                            android:layout_alignParentTop="true"
                            android:layout_alignParentStart="true" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_alignParentBottom="true"
                            android:layout_alignParentStart="true">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/pertemuan_3"
                                android:textColor="#ffffff"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Materi &amp; Tugas"
                                android:textColor="#CCFFFFFF"
                                android:textSize="11sp" />
                        </LinearLayout>

                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ROW 2: Pertemuan 4 dan 5 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- CARD PERTEMUAN 4 — Purple -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/btnToFourth"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#7c3aed">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="14dp">

                        <View
                            android:layout_width="70dp"
                            android:layout_height="70dp"
                            android:background="@drawable/shape_circle_white"
                            android:alpha="0.15"
                            android:layout_alignParentTop="true"
                            android:layout_alignParentEnd="true"
                            android:layout_marginTop="-14dp"
                            android:layout_marginEnd="-14dp" />

                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:gravity="center"
                            android:text="P4"
                            android:textColor="#ffffff"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:background="@drawable/shape_badge_white"
                            android:layout_alignParentTop="true"
                            android:layout_alignParentStart="true" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_alignParentBottom="true"
                            android:layout_alignParentStart="true">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/pertemuan_4"
                                android:textColor="#ffffff"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Materi &amp; Tugas"
                                android:textColor="#CCFFFFFF"
                                android:textSize="11sp" />
                        </LinearLayout>

                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

                <!-- CARD PERTEMUAN 5 — Teal -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/btnToFifth"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#0d9488">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="14dp">

                        <View
                            android:layout_width="70dp"
                            android:layout_height="70dp"
                            android:background="@drawable/shape_circle_white"
                            android:alpha="0.15"
                            android:layout_alignParentTop="true"
                            android:layout_alignParentEnd="true"
                            android:layout_marginTop="-14dp"
                            android:layout_marginEnd="-14dp" />

                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:gravity="center"
                            android:text="P5"
                            android:textColor="#ffffff"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:background="@drawable/shape_badge_white"
                            android:layout_alignParentTop="true"
                            android:layout_alignParentStart="true" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_alignParentBottom="true"
                            android:layout_alignParentStart="true">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/pertemuan_5"
                                android:textColor="#ffffff"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Materi &amp; Tugas"
                                android:textColor="#CCFFFFFF"
                                android:textSize="11sp" />
                        </LinearLayout>

                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- CARD PERTEMUAN 6 — Hijau (full width) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btnToSixth"
                android:layout_width="match_parent"
                android:layout_height="130dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#16a34a">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="14dp">

                    <View
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:background="@drawable/shape_circle_white"
                        android:alpha="0.15"
                        android:layout_alignParentTop="true"
                        android:layout_alignParentEnd="true"
                        android:layout_marginTop="-20dp"
                        android:layout_marginEnd="-20dp" />

                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:gravity="center"
                        android:text="P6"
                        android:textColor="#ffffff"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:background="@drawable/shape_badge_white"
                        android:layout_alignParentTop="true"
                        android:layout_alignParentStart="true" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_alignParentBottom="true"
                        android:layout_alignParentStart="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/pertemuan_6"
                            android:textColor="#ffffff"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Materi &amp; Tugas"
                            android:textColor="#CCFFFFFF"
                            android:textSize="11sp" />
                    </LinearLayout>

                </RelativeLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAVIGATION BAR -->
    <LinearLayout
        android:id="@+id/bottomNavBarContainer"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#CC0f172a"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>